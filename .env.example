# Entra app authentication
SP_EXPORT_TENANT=11111111-2222-3333-4444-555555555555
SP_EXPORT_CLIENT_ID=00000000-0000-0000-0000-000000000000
SP_EXPORT_CERT_PATH=
SP_EXPORT_CERT_THUMBPRINT=

# Export mode (download service)
# Comma or newline separated site URLs. Leave empty when using LIST_FETCHER_LIST_URLS_FILE.
LIST_FETCHER_SITE_URLS=https://contoso.sharepoint.com/sites/finance

# Optional: one full list URL per line inside the mounted container path.
# Example host file: ./config/lists.txt -> container path: /config/lists.txt
LIST_FETCHER_LIST_URLS_FILE=

# Export destination inside the container. With the default volume it lands in ./data on the host.
LIST_FETCHER_OUTPUT_DIR=/data/backup
LIST_FETCHER_INCLUDE_HIDDEN=false

# Restore mode (restore service, profile "tools")
# Example root export dir or a single exported list dir inside ./data on the host.
LIST_FETCHER_RESTORE_PATH=/data/backup

# Optional: override source site and restore into another site
LIST_FETCHER_TARGET_SITE_URL=

# Certificate generator (tools profile service: certgen)
# Output is written to ./certs on the host by default.
LIST_FETCHER_CERT_OUTPUT_DIR=/certs
LIST_FETCHER_CERT_NAME=sharepoint-app
LIST_FETCHER_CERT_COMMON_NAME=list-fetcher
LIST_FETCHER_CERT_DAYS=825
LIST_FETCHER_CERT_FORCE=false
